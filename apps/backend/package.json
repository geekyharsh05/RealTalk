    "express": "^5.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.1",
    "morgan": "^1.10.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1"
