{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "./dist/es/index.js",
  "module": "./dist/es/index.js",
  "types": "./dist/es/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsup src/index.ts --format esm,cjs --watch --onSuccess \"node dist/index.js\"",
    "build": "tsup src/index.ts src/models/user.model.ts src/models/message.model.ts --format esm,cjs --dts",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "test": "jest"
  },
  "exports": {
    "./db": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./models/user": {
      "import": {
        "types": "./dist/models/user.d.ts",
        "default": "./dist/models/user.js"
      },
      "require": {
        "types": "./dist/models/user.d.cts",
        "default": "./dist/models/user.cjs"
      }
    },
    "./models/message": {
      "import": {
        "types": "./dist/models/message.d.ts",
        "default": "./dist/models/message.js"
      },
      "require": {
        "types": "./dist/models/message.d.cts",
        "default": "./dist/models/message.cjs"
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.13.9",
    "bunchee": "^6.4.0",
    "eslint": "^9.23.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@typegoose/typegoose": "^12.14.0",
    "dotenv": "^16.4.7",
    "mongoose": "^8.13.1"
  }
}